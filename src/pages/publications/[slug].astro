---
import { getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatAuthorLine, formatCitationCount, getPublicationPath, sortPublications } from '../../lib/publications';

export async function getStaticPaths() {
  const publications = await getCollection('publications');

  return publications.map((publication) => ({
    params: { slug: publication.data.slug },
    props: { publication },
  }));
}

const { publication } = Astro.props;
const publications = sortPublications(await getCollection('publications'));
const currentIndex = publications.findIndex((entry) => entry.id === publication.id);
const newerPublication = currentIndex > 0 ? publications[currentIndex - 1] : undefined;
const olderPublication = currentIndex < publications.length - 1 ? publications[currentIndex + 1] : undefined;
---

<BaseLayout title={publication.data.title} description={publication.data.description} currentPath="/publications">
  <article class="pb-10 pt-4">
    <header class="border-b border-stone-400/15 pb-12">
      <div class="flex flex-wrap items-center gap-3 text-[0.72rem] uppercase tracking-[0.22em] text-muted">
        <span class="rounded-full bg-accent-soft px-3 py-1 text-accent">{publication.data.venueShort}</span>
        <span>{publication.data.year}</span>
        {publication.data.firstAuthor && (
          <span class="rounded-full border border-stone-300/75 px-3 py-1 text-muted">First author</span>
        )}
      </div>

      <h1 class="mt-6 max-w-4xl font-serif text-[clamp(2.7rem,7vw,4.5rem)] leading-[0.98] tracking-[-0.045em] text-balance text-ink">
        {publication.data.title}
      </h1>

      <p class="mt-6 max-w-3xl text-base leading-8 text-muted sm:text-lg">{publication.data.description}</p>
    </header>

    <div class="mt-12 grid gap-10 xl:grid-cols-[minmax(0,1fr)_280px] xl:gap-14">
      <div class="space-y-8">
        <section class="surface-panel p-7 sm:p-8">
          <p class="section-kicker">Bibliography</p>
          <div class="mt-5 space-y-4 text-base leading-8 text-muted">
            <p><strong class="font-medium text-ink">Authors:</strong> {formatAuthorLine(publication.data.authors)}</p>
            <p><strong class="font-medium text-ink">Venue:</strong> {publication.data.venue}</p>
            <p><strong class="font-medium text-ink">Year:</strong> {publication.data.year}</p>
            <p><strong class="font-medium text-ink">Scholar snapshot:</strong> {formatCitationCount(publication.data.citations)}</p>
          </div>
        </section>

        <section class="surface-panel p-7 sm:p-8">
          <p class="section-kicker">Links</p>
          <div class="mt-5 flex flex-wrap gap-3 text-sm">
            {publication.data.paperUrl && <a class="rounded-full border border-stone-300/80 bg-white/70 px-4 py-2 text-ink hover:text-accent" href={publication.data.paperUrl} target="_blank" rel="noreferrer">Paper page ↗</a>}
            {publication.data.pdfUrl && <a class="rounded-full border border-stone-300/80 bg-white/70 px-4 py-2 text-ink hover:text-accent" href={publication.data.pdfUrl} target="_blank" rel="noreferrer">PDF ↗</a>}
            {publication.data.doiUrl && <a class="rounded-full border border-stone-300/80 bg-white/70 px-4 py-2 text-ink hover:text-accent" href={publication.data.doiUrl} target="_blank" rel="noreferrer">DOI ↗</a>}
            {publication.data.scholarUrl && <a class="rounded-full border border-stone-300/80 bg-white/70 px-4 py-2 text-ink hover:text-accent" href={publication.data.scholarUrl} target="_blank" rel="noreferrer">Scholar ↗</a>}
            {publication.data.codeUrl && <a class="rounded-full border border-stone-300/80 bg-white/70 px-4 py-2 text-ink hover:text-accent" href={publication.data.codeUrl} target="_blank" rel="noreferrer">Code ↗</a>}
            {publication.data.blogSlug && <a class="rounded-full bg-accent px-4 py-2 text-white hover:bg-ink" href={`/writing/${publication.data.blogSlug}/`}>Read blog note</a>}
          </div>
        </section>

        {publication.data.tags.length > 0 && (
          <section class="surface-panel p-7 sm:p-8">
            <p class="section-kicker">Keywords</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {publication.data.tags.map((tag) => (
                <span class="rounded-full border border-stone-300/75 px-3 py-1 text-sm text-muted">{tag}</span>
              ))}
            </div>
          </section>
        )}
      </div>

      <aside class="xl:sticky xl:top-24 xl:self-start">
        <div class="surface-panel p-6">
          <p class="section-kicker">Context</p>
          <dl class="mt-5 space-y-4 text-sm leading-7 text-muted">
            <div>
              <dt class="text-xs uppercase tracking-[0.18em] text-muted">Position</dt>
              <dd class="mt-1">{publication.data.firstAuthor ? 'First author / leading contribution' : 'Co-author contribution'}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-[0.18em] text-muted">Venue short name</dt>
              <dd class="mt-1">{publication.data.venueShort}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-[0.18em] text-muted">Blog availability</dt>
              <dd class="mt-1">{publication.data.blogSlug ? 'Expanded as a site essay' : 'No site note yet'}</dd>
            </div>
          </dl>
        </div>
      </aside>
    </div>

    {(newerPublication || olderPublication) && (
      <section class="mt-16 grid gap-4 border-t border-stone-400/15 pt-10 sm:grid-cols-2">
        {newerPublication ? (
          <a href={getPublicationPath(newerPublication)} class="surface-panel block p-5 hover:border-accent/20">
            <p class="section-kicker">Newer</p>
            <h2 class="mt-3 font-serif text-2xl tracking-[-0.02em] text-ink">{newerPublication.data.title}</h2>
          </a>
        ) : <div></div>}

        {olderPublication && (
          <a href={getPublicationPath(olderPublication)} class="surface-panel block p-5 hover:border-accent/20 sm:text-right">
            <p class="section-kicker">Older</p>
            <h2 class="mt-3 font-serif text-2xl tracking-[-0.02em] text-ink">{olderPublication.data.title}</h2>
          </a>
        )}
      </section>
    )}
  </article>
</BaseLayout>

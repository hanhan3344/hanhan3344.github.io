---
import type { CollectionEntry } from 'astro:content';
import { formatAuthorLine, formatCitationCount, getPublicationPath } from '../lib/publications';

interface Props {
  publication: CollectionEntry<'publications'>;
}

const { publication } = Astro.props;
const href = getPublicationPath(publication);
---

<article class="surface-panel group flex h-full flex-col p-6 sm:p-7">
  <div class="flex flex-wrap items-center gap-2 text-[0.72rem] uppercase tracking-[0.22em] text-muted">
    <span>{publication.data.venueShort}</span>
    <span class="h-px w-8 bg-stone-300/70"></span>
    <span>{publication.data.year}</span>
    {publication.data.firstAuthor && (
      <span class="rounded-full bg-accent-soft px-2.5 py-1 text-[0.65rem] tracking-[0.18em] text-accent">First author</span>
    )}
  </div>

  <h3 class="mt-5 font-serif text-2xl leading-tight tracking-[-0.03em] text-ink transition-colors group-hover:text-accent">
    <a href={href}>{publication.data.title}</a>
  </h3>

  <p class="mt-3 text-sm leading-7 text-muted">{formatAuthorLine(publication.data.authors)}</p>
  <p class="mt-4 flex-1 text-sm leading-7 text-muted sm:text-base">{publication.data.description}</p>

  {publication.data.tags.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-2">
      {publication.data.tags.slice(0, 3).map((tag) => (
        <span class="rounded-full border border-stone-300/75 px-3 py-1 text-[0.72rem] uppercase tracking-[0.14em] text-muted">{tag}</span>
      ))}
    </div>
  )}

  <div class="mt-6 flex flex-wrap items-center gap-4 text-sm">
    <span class="text-muted">{formatCitationCount(publication.data.citations)}</span>
    {publication.data.blogSlug && <a class="research-link" href={`/writing/${publication.data.blogSlug}/`}>Blog note</a>}
    {publication.data.paperUrl && (
      <a class="research-link" href={publication.data.paperUrl} target="_blank" rel="noreferrer">Paper ↗</a>
    )}
  </div>
</article>

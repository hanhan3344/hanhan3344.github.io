---
interface Props {
  title: string;
  description: string;
  tags: string[];
}

const { title, description, tags } = Astro.props;
---

<article class="surface-panel h-full p-6 sm:p-7">
  <p class="section-kicker">Focus</p>
  <h3 class="mt-4 font-serif text-2xl leading-tight tracking-[-0.02em] text-ink">{title}</h3>
  <p class="mt-4 text-sm leading-7 text-muted sm:text-base">{description}</p>

  <div class="mt-6 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="rounded-full bg-accent-soft px-3 py-1 text-xs font-medium tracking-[0.08em] text-accent">{tag}</span>
    ))}
  </div>
</article>

---
import { siteData } from '../data/site';

const year = new Date().getFullYear();
---
<footer class="mx-auto mt-24 w-full max-w-[1180px] px-6 pb-10 sm:px-8 lg:px-10">
  <div class="border-t border-stone-400/15 pt-8 text-sm text-muted">
    <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-2xl space-y-2">
        <p class="font-serif text-lg text-ink">{siteData.name}</p>
        <p>
          Rebuilt from an older Hexo blog into a calmer, more editorial home for long-form technical writing.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-4 text-sm">
        <a class="research-link" href={siteData.github} target="_blank" rel="noreferrer">GitHub</a>
        <a class="research-link" href={siteData.scholar} target="_blank" rel="noreferrer">Scholar</a>
        <a class="research-link" href={`mailto:${siteData.email}`}>Email</a>
        <a class="research-link" href="/writing">Archive</a>
        <a class="research-link" href="/publications">Publications</a>
      </div>
    </div>

    <p class="mt-6 text-xs uppercase tracking-[0.18em] text-muted/80">© {year} {siteData.name} · {siteData.alias}</p>
  </div>
</footer>

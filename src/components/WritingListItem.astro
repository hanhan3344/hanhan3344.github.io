---
import type { CollectionEntry } from 'astro:content';
import { formatDate, getPostPath } from '../lib/posts';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const category = post.data.categories[0] ?? 'Essay';
const href = getPostPath(post);
---

<article class="group relative border-b border-stone-400/12 py-7 last:border-0">
  <div class="grid gap-4 md:grid-cols-[160px_minmax(0,1fr)] md:gap-8">
    <div class="space-y-2 text-sm text-muted">
      <time class="block tabular-nums">{formatDate(post.data.date)}</time>
      <span class="inline-flex rounded-full bg-white/75 px-3 py-1 text-[0.72rem] uppercase tracking-[0.18em] text-accent">{category}</span>
    </div>

    <div class="min-w-0">
      <h3 class="font-serif text-2xl leading-tight tracking-[-0.03em] text-ink transition-colors group-hover:text-accent">
        <a href={href} class="after:absolute after:inset-0 after:content-['']">{post.data.title}</a>
      </h3>
      <p class="mt-3 max-w-3xl text-sm leading-7 text-muted sm:text-base">{post.data.description}</p>

      {post.data.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="rounded-full border border-stone-300/70 px-2.5 py-1 text-xs text-muted">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>
</article>

---
interface Props {
  kicker: string;
  title: string;
  intro?: string;
}

const { kicker, title, intro } = Astro.props;
---

<div class="mb-8 max-w-3xl sm:mb-10">
  <p class="section-kicker">{kicker}</p>
  <h2 class="mt-4 font-serif text-3xl leading-tight tracking-[-0.03em] text-ink sm:text-4xl">{title}</h2>
  {intro && <p class="mt-4 text-base leading-8 text-muted sm:text-lg">{intro}</p>}
</div>

---
import type { CollectionEntry } from 'astro:content';
import { formatDate, getPostPath } from '../lib/posts';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const category = post.data.categories[0] ?? 'Essay';
const href = getPostPath(post);
---

<article class="surface-panel group flex h-full flex-col p-6 sm:p-7">
  <div class="flex items-center gap-3 text-[0.72rem] uppercase tracking-[0.22em] text-muted">
    <span>{category}</span>
    <span class="h-px flex-1 bg-stone-300/70"></span>
    <time>{formatDate(post.data.date)}</time>
  </div>

  <h3 class="mt-6 font-serif text-2xl leading-tight tracking-[-0.03em] text-ink transition-colors group-hover:text-accent">
    <a href={href}>{post.data.title}</a>
  </h3>

  <p class="mt-4 flex-1 text-sm leading-7 text-muted sm:text-base">{post.data.description}</p>

  {post.data.tags.length > 0 && (
    <div class="mt-6 flex flex-wrap gap-2">
      {post.data.tags.slice(0, 3).map((tag) => (
        <span class="rounded-full border border-stone-300/75 px-3 py-1 text-[0.72rem] uppercase tracking-[0.14em] text-muted">{tag}</span>
      ))}
    </div>
  )}
</article>
